<!DOCTYPE html>
<html>
<script src="https://unpkg.com/shpjs@latest/dist/shp.js"></script>
<head>
	<title>Test</title>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link rel="shortcut icon" type="image/x-icon" href="docs/images/favicon.ico">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" integrity="sha512-xodZBNTC5n17Xt2atTPuE1HxjVMSvLVW9ocqUKLsCC5CXdbqCmblAshOMAS6/keqq/sMZMZ19scR4PsZChSR7A==" crossorigin="">
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js" integrity="sha512-XQoYMqMTK8LvdxXYG3nZ448hOEQiglfqkJs1NOQV44cWnUrBc8PkAOcXy20w0vlaXaVUearIOBhiXZ5V3ynxwA==" crossorigin=""></script>

</head>

<body>
<div id="mapid" style="width: 1600px; height: 800px;"></div>





<script>
	var mymap = L.map('mapid').setView([20.7984, -156.3319], 11);
	L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
	maxZoom: 19,
	attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
	}).addTo(mymap);
</script>



<script>
shp("FlightlineDB_Maui").then(function(FlightLines){
	//do something with your geojson
	console.log(FlightLines);
	//var myLayer = L.geoJSON().addTo(mymap);
	//myLayer.addData(FlightLines);
	
	for(var i = 0; i < 3; i++) 
	{
		var obj = FlightLines.features[i];
		console.log(obj);
		
		coord = obj.geometry.coordinates;
		var start = coord[0];
		var end = coord[coord.length-1];
		var mid = [(start[0]+end[0])/2.0, (start[1]+end[1])/2.0];
		var coord_all = [start, mid, end];
		var h_F = obj.properties.Altitude;
		// Match height
		var gh = [0,1000,950,925,900,850,800,700,600,500,400,300,200,150];
		var h_API = ClosestGH(gh,h_F);
		
		console.log(coord_all);
		//console.log(h_F);
		//console.log(h_API);
		
		// Get weather data
		var score = 0;
		for(var i = 0; i < coord_all.length; i++)
		{
			var avg = API(coord_all[i],h_API,score);
			console.log(avg);
		}
		if (avg < 5 || isNaN(avg))
		{
			var myStyle = {
			"color": "#FF3333",
			"weight": 5,
			"opacity": 0.65
			};
			
			L.geoJSON(obj, {
			style: myStyle
			}).addTo(mymap);
		}
		else
		{
			var myStyle = {
			"color": "#3733FF",
			"weight": 5,
			"opacity": 0.65
			};
			L.geoJSON(obj, {
			style: myStyle
			}).addTo(mymap);
		}
	}

	});


function ClosestGH (gh,h_F) {
    var diff_prev = 10000000;
	var closet = 0;
    for (var i = 0; i < gh.length; i++) 
	{
		var curr = gh[i];
		var diff_curr = Math.abs(h_F-curr);
		if (diff_curr < diff_prev)
		{
			diff_prev = diff_curr;
			closest = gh[i];	
		}
    };
	if (closest == 0)
	{
		var h_API = "surface";
	}
	else
	{
		var h_API = closest.toString().concat('h');
	}
    return h_API
}

// Get weather data
function API(coord_all,h_API,score)
{
	var index = 1;
	var result;
	var score_temp = 0;
	var data = JSON.stringify({"lat": coord_all[0],
    "lon": coord_all[1],
    "model": "gfs",
    "parameters": ["wind", "precip", "temp", "lclouds"],
    "levels": ["surface", h_API],
    "key": "0uXnDxpfjW6zJeYqk5W9zVbMH83s3py2"});
	
	var xhr = new XMLHttpRequest();
	var url = "https://api.windy.com/api/point-forecast/v2";
	xhr.open("POST", url, true);
	xhr.setRequestHeader("Content-Type", "application/json");
	xhr.send(data);
	
	xhr.onreadystatechange = function () {
    if (this.readyState === 4 && this.status === 200) 
	{
		result = JSON.parse(this.responseText);
		console.log(result);
		//console.log(new Date(result.ts[0]));
		//console.log(new Date(result.ts[1]));
		// Check index here, what time exactly? current = 1?
		// Apply math model here
		
		// Precip, boolean
		var u = 'wind_u-'.concat(h_API);
		var v = 'wind_v-'.concat(h_API);
		var wind = Math.sqrt(result[u][1]*result[u][1]+result[v][1]*result[v][1]);
		if (result["past3hprecip-surface"][1] == 0 || wind>5 || result["lclouds-surface"][1]>100)
		{
			score = 0;
			console.log("Not suitable");
			//console.log(obj);
			return score
			
		}
		// Wind, 0.5 one level
		else
		{
			var score_all = 1;
			var score_wind = remap(10, wind, 0, 5);
			var score_cloud = remap(10, result["lclouds-surface"][1], 0, 100);
			
			score = score_temp + score_all*(score_wind*0.7+score_cloud*0.3);
			console.log(score);
			return score
		}
		//avg = score_temp/(index-1);
		//console.log(score,score_all,score_wind,score_cloud,isNaN(avg));	
	}
	};
	console.log(result.flat());
	
}



function remap(interval,data,begin,end)
{
	var score = 0;
	var stepsize = (end-begin)/interval;
	for(var i = 0; i < interval+1; i++)
	{
		var curr = begin;
		
		if ((data - begin)>stepsize)
		{
			begin = begin + stepsize;
		}	
		else
		{
			score = 10-i;
			//console.log(data,i,score, begin,stepsize);
			break;
		}
		if (data > end)
		{
			score = 0;
		}	
	}
	
	return score;
}




</script>




</body>
</html>










